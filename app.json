{
  "expo": {
    "name": "TrialCrew",
    "slug": "trialcrew-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "trialcrew",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F5F6FA"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.trialcrew.mobile"
    },
    "android": {
      "package": "app.trialcrew.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#F5F6FA"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3186f91e-29d3-4507-a532-ce8656d6482d"
      }
    },
    "owner": "shahzeb"
  }
}
