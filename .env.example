# Copy to `.env` and restart the dev server with `npx expo start --clear`.

# Use the real Fastify backend (../backend) instead of the in-memory mock.
# Leave unset / "false" to keep using the mock (default).
EXPO_PUBLIC_USE_BACKEND=true

# Backend base URL.
#  - Android emulator:        http://10.0.2.2:4000
#  - iOS simulator:           http://localhost:4000
#  - Physical device (Expo Go): http://<YOUR-COMPUTER-LAN-IP>:4000  (e.g. http://192.168.1.20:4000)
EXPO_PUBLIC_API_URL=http://localhost:4000
